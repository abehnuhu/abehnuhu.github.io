<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>House of Baiden | Premium Fragrances & Skincare — KNUST</title>
<meta name="description" content="Authentic luxury fragrances and premium skincare at student-friendly prices. Located at KNUST, Kumasi. Free campus delivery.">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>
<style>
/* ===================== RESET & BASE ===================== */
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg:           #0a0a0a;
  --surface:      #141414;
  --card:         #1a1a1a;
  --card-hover:   #1f1f1f;
  --border:       rgba(196,167,71,0.18);
  --border-strong:rgba(196,167,71,0.35);
  --gold:         #c4a747;
  --gold-dim:     #9c7c2e;
  --gold-glow:    rgba(196,167,71,0.12);
  --white:        #f8f8f8;
  --muted:        #888;
  --text:         #cccccc;
  --danger:       #e05252;
  --success:      #4caf76;
  --info:         #5b9bd5;
  --whatsapp:     #25D366;
  --whatsapp-dim: #1da851;
  --radius:       14px;
  --radius-sm:    10px;
  --trans:        all 0.25s ease;
  --shadow-sm:    0 2px 8px rgba(0,0,0,0.3);
  --shadow-md:    0 8px 30px rgba(0,0,0,0.4);
  --shadow-lg:    0 20px 60px rgba(0,0,0,0.6);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Inter', 'Segoe UI', sans-serif;
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  overflow-x: hidden;
  min-height: 100vh;
}

h1, h2, h3, h4, h5 {
  font-family: 'Playfair Display', 'Times New Roman', serif;
  color: var(--white);
  font-weight: 500;
  letter-spacing: 0.5px;
}

p { color: var(--text); }

a { color: var(--gold); text-decoration: none; transition: var(--trans); }
a:hover { color: var(--white); }

img { max-width: 100%; display: block; }

section { padding: 80px 20px; }

.container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

.section-header { text-align: center; margin-bottom: 60px; }
.section-header .eyebrow {
  display: inline-block;
  font-size: 0.78rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 14px;
  font-family: 'Inter', sans-serif;
  font-weight: 500;
}
.section-header h2 {
  font-size: clamp(1.8rem, 4vw, 2.75rem);
  margin-bottom: 16px;
  position: relative;
  display: inline-block;
}
.section-header h2::after {
  content: '';
  position: absolute;
  bottom: -12px; left: 50%;
  transform: translateX(-50%);
  width: 60px; height: 2px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}
.section-header p {
  margin-top: 24px;
  max-width: 600px;
  margin-left: auto; margin-right: auto;
  color: var(--muted);
  font-size: 1.05rem;
}

/* ===================== BUTTONS ===================== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 14px 28px;
  border: none;
  border-radius: var(--radius-sm);
  font-family: 'Inter', sans-serif;
  font-size: 0.95rem;
  font-weight: 500;
  letter-spacing: 0.5px;
  cursor: pointer;
  transition: var(--trans);
  text-decoration: none;
  white-space: nowrap;
}
.btn:hover { transform: translateY(-2px); }
.btn:active { transform: translateY(0); }

.btn-primary { background: var(--gold); color: var(--bg); }
.btn-primary:hover { background: var(--gold-dim); color: var(--bg); }

.btn-outline {
  background: transparent;
  color: var(--gold);
  border: 1px solid var(--border-strong);
}
.btn-outline:hover { background: var(--gold-glow); color: var(--gold); }

.btn-whatsapp { background: var(--whatsapp); color: white; }
.btn-whatsapp:hover { background: var(--whatsapp-dim); color: white; }

.btn-ghost { background: rgba(255,255,255,0.05); color: var(--white); }
.btn-ghost:hover { background: rgba(255,255,255,0.1); color: var(--white); }

.btn-lg { padding: 16px 36px; font-size: 1.05rem; }

/* ===================== HEADER ===================== */
header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  padding: 18px 0;
  background: rgba(10,10,10,0.6);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid transparent;
  transition: var(--trans);
}
header.scrolled {
  padding: 12px 0;
  background: rgba(10,10,10,0.92);
  border-bottom-color: var(--border);
  box-shadow: 0 4px 30px rgba(0,0,0,0.5);
}

nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20px;
}

.logo {
  font-family: 'Playfair Display', serif;
  font-size: 1.7rem;
  color: var(--white);
  text-decoration: none;
  letter-spacing: 1px;
  font-weight: 500;
}
.logo span { color: var(--gold); font-weight: 600; }
.logo:hover { color: var(--white); }

.nav-actions { display: flex; align-items: center; gap: 28px; }

.nav-links {
  display: flex;
  list-style: none;
  gap: 32px;
}
.nav-links a {
  color: var(--text);
  text-decoration: none;
  font-size: 0.95rem;
  font-weight: 400;
  position: relative;
  transition: var(--trans);
}
.nav-links a:hover, .nav-links a.active { color: var(--gold); }
.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -6px; left: 0;
  width: 0; height: 1px;
  background: var(--gold);
  transition: width 0.25s ease;
}
.nav-links a:hover::after, .nav-links a.active::after { width: 100%; }

.cart-btn {
  position: relative;
  background: none;
  border: none;
  color: var(--white);
  font-size: 1.15rem;
  cursor: pointer;
  padding: 6px;
  transition: var(--trans);
}
.cart-btn:hover { color: var(--gold); }
.cart-count {
  position: absolute;
  top: -2px; right: -6px;
  background: var(--gold);
  color: var(--bg);
  font-size: 0.68rem;
  font-weight: 700;
  min-width: 18px; height: 18px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 5px;
  font-family: 'Inter', sans-serif;
}

.mobile-menu-btn {
  display: none;
  background: none;
  border: none;
  color: var(--white);
  font-size: 1.3rem;
  cursor: pointer;
  padding: 6px;
}

/* ===================== HERO ===================== */
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  position: relative;
  overflow: hidden;
  padding: 120px 20px 80px;
}
.hero-bg {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(rgba(10,10,10,0.75), rgba(10,10,10,0.85)),
    url('https://images.unsplash.com/photo-1592945403244-b3fbafd7f539?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80');
  background-size: cover;
  background-position: center;
  z-index: -2;
}
.hero-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at center, transparent 0%, rgba(10,10,10,0.5) 100%);
  z-index: -1;
}
.hero-content {
  max-width: 880px;
  position: relative;
  z-index: 1;
}
.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 8px 18px;
  border: 1px solid var(--border-strong);
  border-radius: 30px;
  background: rgba(196,167,71,0.08);
  font-size: 0.8rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 28px;
  font-weight: 500;
  backdrop-filter: blur(6px);
}
.hero-eyebrow i { font-size: 0.7rem; }
.hero h1 {
  font-size: clamp(2.5rem, 7vw, 5rem);
  margin-bottom: 18px;
  letter-spacing: 1.5px;
  line-height: 1.1;
  background: linear-gradient(180deg, var(--white) 0%, #b8b8b8 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}
.hero-subtitle {
  font-size: clamp(1rem, 2.5vw, 1.4rem);
  color: var(--gold);
  margin-bottom: 18px;
  letter-spacing: 4px;
  text-transform: uppercase;
  font-family: 'Inter', sans-serif;
  font-weight: 400;
}
.hero-tagline {
  font-size: clamp(1.1rem, 2vw, 1.5rem);
  margin-bottom: 40px;
  font-style: italic;
  color: var(--white);
  font-family: 'Playfair Display', serif;
  font-weight: 400;
  max-width: 720px;
  margin-left: auto; margin-right: auto;
}
.hero-cta {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 60px;
}
.hero-cta .btn-perfume {
  background: linear-gradient(135deg, rgba(196,167,71,0.95), rgba(156,124,46,0.95));
  color: var(--bg);
}
.hero-cta .btn-skincare {
  background: transparent;
  color: var(--white);
  border: 1px solid var(--border-strong);
}
.hero-cta .btn-skincare:hover {
  background: var(--gold-glow);
  border-color: var(--gold);
}

.hero-stats {
  display: flex;
  gap: 50px;
  justify-content: center;
  flex-wrap: wrap;
  padding-top: 30px;
  border-top: 1px solid rgba(255,255,255,0.08);
  max-width: 700px;
  margin: 0 auto;
}
.hero-stat {
  text-align: center;
}
.hero-stat .num {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  color: var(--gold);
  font-weight: 600;
  display: block;
}
.hero-stat .lbl {
  font-size: 0.78rem;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--muted);
}

/* ===================== TRUST BADGES ===================== */
.trust {
  background: var(--surface);
  padding: 32px 20px;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
.trust-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  max-width: 1200px;
  margin: 0 auto;
}
.trust-item {
  display: flex;
  align-items: center;
  gap: 14px;
  justify-content: center;
}
.trust-item i {
  font-size: 1.6rem;
  color: var(--gold);
  width: 32px;
  text-align: center;
}
.trust-item .txt { font-size: 0.85rem; color: var(--white); font-weight: 500; }
.trust-item .sub { font-size: 0.75rem; color: var(--muted); }

/* ===================== CATEGORIES ===================== */
.categories-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 30px;
}
.category-card {
  position: relative;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 44px 32px;
  text-align: center;
  transition: var(--trans);
  text-decoration: none;
  color: var(--text);
  overflow: hidden;
}
.category-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  transform: scaleX(0);
  transition: transform 0.3s ease;
}
.category-card:hover {
  transform: translateY(-8px);
  border-color: var(--border-strong);
  box-shadow: var(--shadow-md);
  background: var(--card-hover);
}
.category-card:hover::before { transform: scaleX(1); }
.category-card .icon-wrap {
  width: 80px; height: 80px;
  margin: 0 auto 24px;
  border-radius: 50%;
  background: var(--gold-glow);
  border: 1px solid var(--border-strong);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.2rem;
  color: var(--gold);
  transition: var(--trans);
}
.category-card:hover .icon-wrap {
  transform: rotate(-5deg) scale(1.05);
  background: var(--gold);
  color: var(--bg);
}
.category-card h3 {
  font-size: 1.7rem;
  margin-bottom: 12px;
  color: var(--white);
}
.category-card p {
  color: var(--muted);
  margin-bottom: 24px;
  font-size: 0.95rem;
}
.category-card .cat-stats {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 14px;
  background: var(--gold-glow);
  border: 1px solid var(--border);
  border-radius: 30px;
  font-size: 0.82rem;
  color: var(--gold);
  margin-bottom: 24px;
  font-weight: 500;
}
.category-card .cat-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: var(--gold);
  font-size: 0.9rem;
  font-weight: 500;
  letter-spacing: 0.5px;
}
.category-card .cat-link i { transition: var(--trans); }
.category-card:hover .cat-link i { transform: translateX(4px); }

/* ===================== FEATURED PRODUCTS ===================== */
.featured-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 24px;
}
.product-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  transition: var(--trans);
  display: flex;
  flex-direction: column;
}
.product-card:hover {
  transform: translateY(-6px);
  border-color: var(--border-strong);
  box-shadow: var(--shadow-md);
}
.product-img-wrap {
  position: relative;
  background: var(--surface);
  aspect-ratio: 1;
  overflow: hidden;
}
.product-img-wrap img {
  width: 100%; height: 100%;
  object-fit: contain;
  padding: 20px;
  transition: transform 0.4s ease;
}
.product-card:hover .product-img-wrap img { transform: scale(1.06); }
.product-cat-tag {
  position: absolute;
  top: 12px; left: 12px;
  background: rgba(10,10,10,0.7);
  backdrop-filter: blur(6px);
  color: var(--gold);
  padding: 5px 12px;
  border-radius: 20px;
  font-size: 0.7rem;
  letter-spacing: 1px;
  text-transform: uppercase;
  font-weight: 500;
  border: 1px solid var(--border);
}
.product-info {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}
.product-name {
  font-family: 'Playfair Display', serif;
  font-size: 1.15rem;
  color: var(--white);
  font-weight: 500;
}
.product-desc {
  font-size: 0.82rem;
  color: var(--muted);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  min-height: 40px;
}
.product-price {
  font-size: 1.35rem;
  color: var(--gold);
  font-weight: 600;
  font-family: 'Playfair Display', serif;
  margin-top: auto;
}
.product-actions {
  display: flex;
  gap: 8px;
  padding: 0 20px 20px;
}
.product-actions .btn {
  flex: 1;
  padding: 10px 14px;
  font-size: 0.85rem;
}
.btn-add-cart {
  background: var(--gold-glow);
  color: var(--gold);
  border: 1px solid var(--border);
  flex: 0 0 44px;
  padding: 10px;
}
.btn-add-cart:hover { background: var(--gold); color: var(--bg); }

/* Skeleton loaders */
.skeleton-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}
.skeleton-img {
  aspect-ratio: 1;
  background: linear-gradient(90deg, var(--surface) 25%, var(--card-hover) 50%, var(--surface) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}
.skeleton-body { padding: 20px; }
.skeleton-line {
  height: 14px;
  background: linear-gradient(90deg, var(--surface) 25%, var(--card-hover) 50%, var(--surface) 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 4px;
  margin-bottom: 10px;
}
.skeleton-line.short { width: 60%; }
.skeleton-line.med { width: 80%; }
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===================== WHY CHOOSE ===================== */
.why-choose { background: var(--surface); }
.benefits-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 24px;
}
.benefit {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 36px 28px;
  transition: var(--trans);
  position: relative;
  overflow: hidden;
}
.benefit::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 4px; height: 100%;
  background: var(--gold);
  transform: scaleY(0);
  transform-origin: bottom;
  transition: transform 0.3s ease;
}
.benefit:hover { background: var(--card-hover); transform: translateY(-4px); }
.benefit:hover::before { transform: scaleY(1); transform-origin: top; }
.benefit .icon-wrap {
  width: 56px; height: 56px;
  border-radius: 12px;
  background: var(--gold-glow);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  color: var(--gold);
  margin-bottom: 20px;
}
.benefit h3 {
  font-size: 1.3rem;
  margin-bottom: 12px;
  color: var(--white);
}
.benefit p {
  color: var(--muted);
  font-size: 0.95rem;
  line-height: 1.7;
}

/* ===================== TESTIMONIALS ===================== */
.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 24px;
}
.testimonial {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 32px 28px;
  position: relative;
  transition: var(--trans);
}
.testimonial:hover { border-color: var(--border-strong); transform: translateY(-4px); }
.testimonial .quote-mark {
  position: absolute;
  top: 18px; right: 24px;
  font-family: 'Playfair Display', serif;
  font-size: 4rem;
  color: var(--gold-glow);
  line-height: 1;
}
.testimonial .stars {
  color: var(--gold);
  margin-bottom: 16px;
  font-size: 0.9rem;
  letter-spacing: 2px;
}
.testimonial .quote {
  color: var(--text);
  font-size: 0.95rem;
  line-height: 1.7;
  margin-bottom: 24px;
  font-style: italic;
}
.testimonial .author {
  display: flex;
  align-items: center;
  gap: 12px;
}
.testimonial .avatar {
  width: 44px; height: 44px;
  border-radius: 50%;
  background: var(--gold);
  color: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
}
.testimonial .author-name { color: var(--white); font-weight: 500; font-size: 0.95rem; }
.testimonial .author-role { color: var(--muted); font-size: 0.8rem; }

/* ===================== WHATSAPP CTA ===================== */
.whatsapp-cta {
  background:
    linear-gradient(135deg, rgba(37,211,102,0.08), rgba(37,211,102,0.04)),
    var(--card);
  border: 1px solid rgba(37,211,102,0.3);
  border-radius: var(--radius);
  padding: 56px 40px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.whatsapp-cta::before {
  content: '';
  position: absolute;
  top: -50%; right: -10%;
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(37,211,102,0.15), transparent 70%);
  pointer-events: none;
}
.whatsapp-cta .icon {
  font-size: 3rem;
  color: var(--whatsapp);
  margin-bottom: 20px;
}
.whatsapp-cta h3 {
  font-size: 1.8rem;
  color: var(--white);
  margin-bottom: 12px;
}
.whatsapp-cta p {
  max-width: 500px;
  margin: 0 auto 28px;
  color: var(--text);
}

/* ===================== LOCATION ===================== */
.location { background: var(--surface); }
.location-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 50px;
  align-items: stretch;
}
.location-map {
  border-radius: var(--radius);
  overflow: hidden;
  border: 1px solid var(--border);
  min-height: 400px;
  background: var(--card);
}
.location-map iframe { width: 100%; height: 100%; min-height: 400px; border: 0; display: block; }
.location-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 18px;
}
.location-info h3 {
  font-size: 1.8rem;
  color: var(--white);
  margin-bottom: 8px;
}
.location-info .loc-tagline {
  color: var(--gold);
  font-size: 0.85rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 16px;
  font-family: 'Inter', sans-serif;
  font-weight: 500;
}
.location-info .info-row {
  display: flex;
  align-items: flex-start;
  gap: 14px;
